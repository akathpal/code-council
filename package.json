{
  "name": "code-council",
  "version": "0.1.0",
  "description": "A local coding workspace that coordinates AI agents with reusable repository memory, evidence-backed planning, and human-reviewed execution.",
  "license": "MIT",
  "author": "code-council contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akathpal/code-council.git"
  },
  "homepage": "https://github.com/akathpal/code-council#readme",
  "bugs": {
    "url": "https://github.com/akathpal/code-council/issues"
  },
  "keywords": [
    "coding-agent",
    "codex",
    "claude-code",
    "multi-agent",
    "repository-context",
    "openhands"
  ],
  "private": true,
  "bin": {
    "council": "bin/council.mjs"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "doctor": "node bin/council.mjs doctor",
    "dev": "node bin/council.mjs --dev",
    "restart": "node bin/council.mjs --restart",
    "stop": "node bin/council.mjs stop",
    "web:dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "ide:build": "tsc -p ide/extension/tsconfig.json",
    "ide:package": "node ide/scripts/package-extension.mjs",
    "ide:prepare": "node ide/scripts/prepare-code-oss.mjs",
    "start": "node bin/council.mjs",
    "web:start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "openhands": "agent-canvas --backend-only --port 8001",
    "test": "npm run build && node --test tests/*.test.ts tests/*.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@openhands/agent-canvas": "1.5.0",
    "drizzle-orm": "0.45.2",
    "next": "16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/vscode": "1.125.0",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "@vscode/vsce": "3.9.2",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.11",
    "jsdom": "29.1.1",
    "react-server-dom-webpack": "19.2.8",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "overrides": {
    "postcss": "8.5.22"
  },
  "type": "module"
}
